# Cluster Configuration
# Copy this file to your project's config/cluster.toml and customize

[cluster]
name = "mycluster"
host = "login.mycluster.edu"      # SSH host alias (configure in ~/.ssh/config)
user = ""                          # Leave empty to use SSH config
scratch_root = "~/projects/myproject"  # Remote project directory

[slurm]
partition = "general"
account = "myaccount"
time_default = "01:00:00"
mem_default = "8G"
nodes_default = 1
cpus_default = 4

[sync]
# Files/patterns to exclude from sync
exclude = [
    ".git",
    "__pycache__",
    "*.pyc",
    ".lake",
    "build",
    ".DS_Store",
    "node_modules",
    ".julia",
    "*.out",
    "*.err"
]
# Whether to sync data directory (usually retrieved separately)
include_data = false

[paths]
# Remote paths to language runtimes (if not in PATH)
julia = "julia"
python = "python3"
lean = "lake"
